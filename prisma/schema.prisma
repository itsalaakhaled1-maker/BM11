generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth.js Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// BM11 Models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("RESEARCHER")
  accounts      Account[]
  sessions      Session[]
  runs          ResearchRun[]
  createdAt     DateTime  @default(now())
}

model ResearchRun {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id])
  topic             String
  initiativeTitle   String
  initiativeSummary String
  localEntity       String
  status            String    @default("PENDING")
  mode              String    @default("REVIEW_CRITICAL")
  stages            Stage[]
  artifacts         Artifact[]
  paper             Paper?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Stage {
  id          String      @id @default(cuid())
  runId       String
  run         ResearchRun @relation(fields: [runId], references: [id])
  number      Int
  phase       String
  name        String
  status      String      @default("PENDING")
  input       String?
  output      String?
  artifacts   Artifact[]
  hitlReason  String?
  startedAt   DateTime?
  completedAt DateTime?
}

model Artifact {
  id          String      @id @default(cuid())
  runId       String
  run         ResearchRun @relation(fields: [runId], references: [id])
  stageId     String?
  stage       Stage?      @relation(fields: [stageId], references: [id])
  type        String
  content     String
  citations   Citation[]
  verified    Boolean     @default(false)
  createdAt   DateTime    @default(now())
}

model Citation {
  id              String    @id @default(cuid())
  artifactId      String
  artifact        Artifact  @relation(fields: [artifactId], references: [id])
  title           String
  authors         String
  year            Int?
  venue           String?
  doi             String?
  url             String?
  s2Id            String?
  relevanceScore  Float?
  verified        Boolean   @default(false)
  verificationLog String?
}

model Paper {
  id          String      @id @default(cuid())
  runId       String      @unique
  run         ResearchRun @relation(fields: [runId], references: [id])
  title       String
  abstract    String
  sections    String
  citations   String
  latex       String?
  pdfUrl      String?
  peerReviews String?
  qualityScore Float?
  createdAt   DateTime    @default(now())
}

model MetaClawSkill {
  id          String   @id @default(cuid())
  name        String
  description String
  pattern     String
  successRate Float
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
}